# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Google OAuth (optional but recommended) ───────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — get by running: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — dashboard.stripe.com → Products → add two prices:
#   Monthly: $7.99 / month (recurring)
#   Yearly:  $74.00 / year (recurring)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ─── Database ──────────────────────────────────────────────────────────────────
# Recommended: Supabase (free tier) → supabase.com → new project → Settings → Database → Connection string
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=
