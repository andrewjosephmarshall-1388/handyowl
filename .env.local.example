# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Use http://localhost:3000 for local dev, your real origin in production.
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Google OAuth (optional — email/password works without this) ───────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys (use Test-mode keys for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — get by running: stripe listen --forward-to localhost:3000/api/stripe/webhook
# The CLI prints a fresh whsec_... each session; paste it here and restart dev server.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — dashboard.stripe.com → Products → create two recurring prices:
#   Monthly: $7.99 / month
#   Yearly:  $74.00 / year
# Copy each price's ID (shown on its product page) into the matching variable.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ─── Database ──────────────────────────────────────────────────────────────────
# Recommended: Supabase (free tier) → supabase.com → new project.
#
# Use the Session Pooler connection string (IPv4-compatible, port 5432) — the
# direct db.[ref].supabase.co host is IPv6-only on the free tier and usually
# fails from home networks.
#
# Find it: Supabase → Connect → Session pooler → URI. URL-encode any special
# characters in your password (e.g. `!` → `%21`).
#
# Format: postgresql://postgres.[project-ref]:[url-encoded-password]@aws-[N]-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=
