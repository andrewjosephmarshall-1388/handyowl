// Handy Owl — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(cuid())
  name                 String?
  email                String         @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  plan                 Plan           @default(FREE)
  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  subscriptionStatus   String?        // active | past_due | canceled
  subscriptionEndsAt   DateTime?
  // Creator attribution: slug of the creator whose referral link brought this
  // user in (set once at signup from the handy_owl_ref cookie).
  // Null means organic/unattributed. Used for the 30%/12mo rev-share.
  referredBy           String?
  referredAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  accounts   Account[]
  sessions   Session[]
  progress   GuideProgress[]
  saved      SavedGuide[]

  @@index([referredBy])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuideProgress {
  id                String   @id @default(cuid())
  userId            String
  guideSlug         String
  stepsComplete     Int      @default(0)
  totalSteps        Int
  completed         Boolean  @default(false)
  // CSV of completed step indices, e.g. "0,2,3". Simple encoding; no join
  // table needed. Migrate to JSON column if per-step metadata is ever needed.
  completedStepsCsv String?  @default("")
  startedAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guideSlug])
  @@index([userId, updatedAt])
}

model SavedGuide {
  id        String   @id @default(cuid())
  userId    String
  guideSlug String
  savedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guideSlug])
}

model EmailCapture {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // 'landing_hero' | 'landing_footer' | 'guide_paywall'
  createdAt DateTime @default(now())
}

enum Plan {
  FREE
  PREMIUM
}
